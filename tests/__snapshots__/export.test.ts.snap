    "content": "import { AIBuilderLandingPage } from "./frames/AIBuilderLandingPage";
import { AIBuilderDashboardFrame } from "./frames/AIBuilderDashboardFrame";

export function App() {
  return (
    <main className="flex min-h-screen flex-col gap-8 bg-slate-100 p-8">
      <AIBuilderLandingPage />
      <AIBuilderDashboardFrame />
    </main>
  );
}

export default App;
